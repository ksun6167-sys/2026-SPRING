}

function getCombinedStrengths(){
  const portfolioStrengths = analyzeStrengths(getData()).strengths;
  const text = getCombinedText();
  const extraRules = [
    {keyword:'주도성', words:['주도','먼저','제안','리드','기획','도전']},
    {keyword:'소통력', words:['소통','협업','조율','회의','갈등','설득','발표']},
    {keyword:'문제 해결력', words:['문제','해결','개선','실패','보완','피드백']},
    {keyword:'책임감', words:['책임','마감','관리','운영','성실','꾸준']},
    {keyword:'학습력', words:['학습','공부','성장','스터디','연습','전공']},
    {keyword:'실행력', words:['실행','제작','완성','진행','성과','결과']}
  ];
  const extraStrengths = extraRules
    .map(rule=>({...rule, score: countMatches(text, rule.words)}))
    .filter(rule=>rule.score > 0)
    .sort((a,b)=>b.score - a.score)
    .map(rule=>rule.keyword);
  return [...new Set([...portfolioStrengths, ...extraStrengths])].slice(0, 5);
}

function getImportantMaterials(){
  const portfolios = getData()
    .filter(v=>v.important)
    .concat(getData().filter(v=>!v.important))
    .slice(0, 3)
    .map(v=>v.title)
    .filter(Boolean);
  const experiences = getExperiences()
    .filter(v=>v.important)
    .concat(getExperiences().filter(v=>!v.important))
    .slice(0, 3)
    .map(v=>v.title)
    .filter(Boolean);
  return {portfolios, experiences};
}

function createOutlineItem(title, body){
  const item = document.createElement('article');
  item.className = 'outline-item';
  appendText(item, 'h3', title);
  appendText(item, 'p', body);
  return item;
}

function generateCoverLetterOutline(force = true){
  const result = document.getElementById('outlineResult');
  if(!force && result.dataset.generated !== 'true') return;

  const profile = getProfile();
  const portfolios = getData();
  const experiences = getExperiences();
  const hasData = Object.values(profile).some(Boolean) || portfolios.length || experiences.length;

  result.className = '';
  result.replaceChildren();

  if(!hasData){
    result.className = 'empty';
    result.textContent = '개요를 만들 데이터가 없습니다. 인적사항, 포트폴리오, 자유경험 중 하나 이상을 입력해 주세요.';
    result.dataset.generated = 'false';
    return;
  }

  const jobs = analyzeJobs(portfolios);
  const strengths = getCombinedStrengths();
  const materials = getImportantMaterials();
  const target = profile.target || (jobs[0] ? jobs[0].name : '지원 직무');
  const major = profile.major || profile.education || '나의 배경';
  const topStrengths = strengths.length ? strengths.slice(0, 3).join(', ') : '성실함, 책임감, 성장 가능성';
  const mainPortfolio = materials.portfolios[0] || '대표 포트폴리오';
  const mainExperience = materials.experiences[0] || '자유경험 기록';

  const list = document.createElement('div');
  list.className = 'outline-list';
  [
    ['1. 도입: 지원 분야와 나의 방향성', `${profile.name ? profile.name + '은/는 ' : ''}${major}을 바탕으로 ${target} 분야에 관심을 갖게 되었음을 밝힙니다. 관심이 단순한 희망이 아니라 실제 기록과 경험으로 이어졌다는 흐름을 첫 문단에서 잡습니다.`],
    ['2. 핵심 강점', `${topStrengths}을 핵심 키워드로 잡고, 주장만 쓰기보다 포트폴리오와 자유경험에서 확인되는 행동을 근거로 연결합니다.`],
    ['3. 대표 경험 1: 포트폴리오', `${mainPortfolio} 경험을 중심 사례로 사용합니다. 맡은 역할, 사용한 스킬, 결과를 순서대로 정리하면 직무 역량을 보여주는 문단이 됩니다.`],
    ['4. 대표 경험 2: 자유경험', `${mainExperience} 경험에서는 상황, 행동, 결과/배운 점을 STAR 구조로 정리합니다. 성격의 장점이나 협업 태도를 보여주는 문단으로 쓰기 좋습니다.`],
    ['5. 마무리: 입사 후 기여 방향', `${target}에서 지금까지 쌓은 경험을 어떻게 확장할지 씁니다. 앞으로 배우고 싶은 점과 조직에 기여할 수 있는 방식을 한 문단으로 정리합니다.`]
  ].forEach(([title, body])=>list.appendChild(createOutlineItem(title, body)));

  const materialPanel = document.createElement('div');
  materialPanel.className = 'analysis-panel';
  appendText(materialPanel, 'h3', '개요에 넣기 좋은 재료');
  appendKeywordList(materialPanel, [
    ...strengths.slice(0, 5),
    ...materials.portfolios.slice(0, 2),
    ...materials.experiences.slice(0, 2)
  ].filter(Boolean));

  result.dataset.generated = 'true';
  result.append(list, materialPanel);
}

function exportData(){
  const data = JSON.stringify({
    profile: getProfile(),
    portfolio: getData(),
    experiences: getExperiences()
  }, null, 2);
  const blob = new Blob([data], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'portfolio.json';
  a.click();
  URL.revokeObjectURL(a.href);
}

function importData(e){
  const file = e.target.files[0];
  if(!file) return;

  const reader = new FileReader();
  reader.onload = ()=>{
    try{
      const parsed = JSON.parse(reader.result);
      if(Array.isArray(parsed)){
        saveData(parsed);
      }else if(parsed && typeof parsed === 'object'){
        if(parsed.profile && typeof parsed.profile === 'object') saveProfileData(parsed.profile);
        if(Array.isArray(parsed.portfolio)) saveData(parsed.portfolio);
        if(Array.isArray(parsed.experiences)) saveExperiences(parsed.experiences);
      }else{
        throw new Error('Invalid portfolio data');
      }
      resetForm();
      resetExperienceForm();
      renderProfile();
      renderExperiences();
      render();
      generateCoverLetterOutline(false);
    }catch{
      alert('가져올 수 없는 JSON 파일입니다.');
    }finally{
      e.target.value = '';
    }
  };
  reader.readAsText(file);
}

renderProfile();
renderExperiences();
render();
</script>
