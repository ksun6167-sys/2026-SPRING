function getFilteredData(){
  const keyword = document.getElementById('search').value.trim().toLowerCase();
  const filterVal = document.getElementById('filter').value;
  return getData().filter(v=>{
    const haystack = [v.title, v.desc, v.role, v.result, ...(Array.isArray(v.skills) ? v.skills : [])]
      .join(' ')
      .toLowerCase();
    const matchKeyword = !keyword || haystack.includes(keyword);
    const matchFilter = filterVal === 'all'
      ? true
      : filterVal === 'important'
        ? v.important
        : v.category === filterVal;
    return matchKeyword && matchFilter;
  });
}

