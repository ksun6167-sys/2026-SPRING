function countMatches(text, words){
  return words.reduce((score, word)=>{
    const escaped = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const matches = text.match(new RegExp(escaped, 'gi'));
    return score + (matches ? matches.length : 0);
  }, 0);
}

