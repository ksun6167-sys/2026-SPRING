<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>포트폴리오 기록 관리</title>
<style>
body{margin:0;font-family:sans-serif;background:#f3f4f6;color:#111}
.container{max-width:1000px;margin:0 auto;padding:30px}
h1{text-align:center;margin-bottom:20px}

.toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px}
.toolbar input, .toolbar select{padding:8px;border-radius:6px;border:1px solid #ccc}

.input-box{background:#fff;padding:15px;border-radius:10px;margin-bottom:20px}
.input-box input, .input-box textarea, .input-box select{
 width:100%;margin-bottom:8px;padding:8px;border-radius:6px;border:1px solid #ccc
}
button{padding:10px;border:none;border-radius:6px;background:#2563eb;color:white;cursor:pointer}

.list{display:flex;flex-direction:column;gap:10px}
.card{background:#fff;padding:15px;border-radius:10px;position:relative}
.card h3{margin:0 0 5px}
.meta{font-size:13px;color:#555;margin-bottom:5px}
.tag{font-size:12px;background:#e5e7eb;padding:2px 6px;border-radius:4px;margin-right:4px}

.actions{position:absolute;top:10px;right:10px;display:flex;gap:5px}
.actions button{padding:5px 8px;font-size:12px}
.star{background:#f59e0b}
.delete{background:#ef4444}
.edit{background:#10b981}

.detail{margin-top:8px;font-size:14px;white-space:pre-wrap}

.export-box{margin-top:20px}
.export-box button{background:#111}
</style>
</head>
<body>
<div class="container">
<h1>📂 포트폴리오 기록 관리</h1>

<div class="input-box">
<input id="title" placeholder="제목">
<select id="category">
<option value="영상">영상</option>
<option value="대외활동">대외활동</option>
<option value="알바">알바</option>
<option value="학업">학업</option>
</select>
<input id="role" placeholder="역할">
<input id="skills" placeholder="스킬 (쉼표로 구분)">
<input id="dateStart" placeholder="시작 날짜">
<input id="dateEnd" placeholder="종료 날짜">
<textarea id="desc" placeholder="설명"></textarea>
<input id="result" placeholder="성과">
<input id="link" placeholder="링크 (선택)">
<button onclick="add()">추가 / 수정</button>
</div>

<div class="toolbar">
<input id="search" placeholder="검색" oninput="render()">
<select id="filter" onchange="render()">
<option value="all">전체</option>
<option value="영상">영상</option>
<option value="대외활동">대외활동</option>
<option value="알바">알바</option>
<option value="학업">학업</option>
<option value="important">⭐ 중요만</option>
</select>
<button onclick="showPortfolio()">포트폴리오 보기</button>
</div>

<div class="list" id="list"></div>

<div class="export-box">
<button onclick="exportData()">데이터 다운로드(JSON)</button>
<input type="file" onchange="importData(event)">
</div>
</div>

<script>
let editId = null;

function getData(){return JSON.parse(localStorage.getItem('portfolio'))||[]}
function saveData(data){localStorage.setItem('portfolio', JSON.stringify(data))}

function add(){
 const item={
  id: editId || Date.now(),
  title:title.value,
  category:category.value,
  role:role.value,
  skills:skills.value.split(',').map(s=>s.trim()),
  dateStart:dateStart.value,
  dateEnd:dateEnd.value,
  desc:desc.value,
  result:result.value,
  link:link.value,
  important:false
 }
 let data=getData();
 if(editId){
  data = data.map(v=>v.id===editId?item:v);
  editId=null;
 } else {
  data.push(item);
 }
 saveData(data);
 document.querySelectorAll('.input-box input, .input-box textarea').forEach(i=>i.value='');
 render();
}

function editItem(id){
 const v = getData().find(x=>x.id===id);
 title.value=v.title;
 category.value=v.category;
 role.value=v.role;
 skills.value=v.skills.join(', ');
 dateStart.value=v.dateStart;
 dateEnd.value=v.dateEnd;
 desc.value=v.desc;
 result.value=v.result;
 link.value=v.link;
 editId=id;
}

function toggleStar(id){
 const data=getData().map(v=>v.id===id?{...v,important:!v.important}:v);
 saveData(data);
 render();
}

function remove(id){
 const data=getData().filter(v=>v.id!==id);
 saveData(data);
 render();
}

function render(){
 const data=getData();
 const keyword=search.value.toLowerCase();
 const filterVal=filter.value;

 let filtered=data.filter(v=>{
  const matchKeyword = v.title.toLowerCase().includes(keyword) || v.desc.toLowerCase().includes(keyword);
  const matchFilter =
   filterVal==='all' ? true :
   filterVal==='important' ? v.important :
   v.category===filterVal;
  return matchKeyword && matchFilter;
 });

 list.innerHTML='';
 filtered.slice().reverse().forEach(v=>{
  const el=document.createElement('div');
  el.className='card';
  el.innerHTML=`
   <div class="actions">
    <button class="star" onclick="toggleStar(${v.id})">${v.important?'★':'☆'}</button>
    <button class="edit" onclick="editItem(${v.id})">수정</button>
    <button class="delete" onclick="remove(${v.id})">삭제</button>
   </div>
   <h3>${v.title}</h3>
   <div class="meta">${v.category} | ${v.dateStart} ~ ${v.dateEnd}</div>
   <div>${v.skills.map(s=>`<span class='tag'>${s}</span>`).join('')}</div>
   <div class="detail">${v.desc}</div>
   <div class="meta">🎬 ${v.role}</div>
   <div class="meta">📊 ${v.result}</div>
   ${v.link?`<a href="${v.link}" target="_blank">링크 보기</a>`:''}
  `;
  list.appendChild(el);
 });
}

function showPortfolio(){
 const data=getData().filter(v=>v.important);
 list.innerHTML='';
 data.forEach(v=>{
  const el=document.createElement('div');
  el.className='card';
  el.innerHTML=`
   <h3>${v.title}</h3>
   <div class="meta">${v.dateStart} ~ ${v.dateEnd}</div>
   <div class="detail">${v.desc}</div>
   <div class="meta">🎬 ${v.role}</div>
   <div class="meta">📊 ${v.result}</div>
  `;
  list.appendChild(el);
 });
}

function exportData(){
 const data = JSON.stringify(getData());
 const blob = new Blob([data], {type:"application/json"});
 const a = document.createElement('a');
 a.href = URL.createObjectURL(blob);
 a.download = 'portfolio.json';
 a.click();
}

function importData(e){
 const file = e.target.files[0];
 const reader = new FileReader();
 reader.onload = ()=>{
  localStorage.setItem('portfolio', reader.result);
  render();
 };
 reader.readAsText(file);
}

render();
</script>
</body>
</html>
