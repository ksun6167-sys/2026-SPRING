function countValues(values){
  const counts = new Map();
  values.filter(Boolean).forEach(value=>{
    counts.set(value, (counts.get(value) || 0) + 1);
  });
  return [...counts.entries()].sort((a,b)=>b[1] - a[1]);
}

function getMonthKey(dateText){
  if(!dateText) return '';
  return dateText.slice(0, 7);
}

function getDateValue(dateText){
  const time = new Date(dateText || '').getTime();
  return Number.isFinite(time) ? time : null;
}

function appendBarChart(parent, entries){
  const list = document.createElement('div');
  list.className = 'bar-list';
  const max = Math.max(...entries.map(([,count])=>count), 1);

  entries.forEach(([label, count])=>{
    const row = document.createElement('div');
    const labelRow = document.createElement('div');
    labelRow.className = 'bar-label';
    appendText(labelRow, 'span', label);
    appendText(labelRow, 'strong', `${count}개`);

    const track = document.createElement('div');
    track.className = 'bar-track';
    const fill = document.createElement('div');
    fill.className = 'bar-fill';
    fill.style.width = `${Math.max(8, Math.round((count / max) * 100))}%`;
    track.appendChild(fill);

    row.append(labelRow, track);
    list.appendChild(row);
  });

  parent.appendChild(list);
}

function appendSkillCloud(parent, entries){
  const cloud = document.createElement('div');
  cloud.className = 'skill-cloud';
  const max = Math.max(...entries.map(([,count])=>count), 1);

  entries.forEach(([skill, count])=>{
    const bubble = appendText(cloud, 'span', skill, 'skill-bubble');
    const size = 13 + Math.round((count / max) * 10);
    bubble.style.fontSize = `${size}px`;
    bubble.title = `${count}회`;
  });

  parent.appendChild(cloud);
}

function appendTimeline(parent, items){
  const validItems = items
    .map(v=>{
      const start = getDateValue(v.dateStart);
      const rawEnd = getDateValue(v.dateEnd) || start;
      const end = rawEnd && start ? Math.max(start, rawEnd) : start;
      return start ? {...v, start, end} : null;
    })
    .filter(Boolean)
    .sort((a,b)=>a.start - b.start);

  if(!validItems.length){
    appendText(parent, 'div', '날짜가 입력된 기록이 있으면 타임라인이 표시됩니다.', 'meta');
    return;
  }

  const min = Math.min(...validItems.map(v=>v.start));
  const max = Math.max(...validItems.map(v=>v.end));
  const range = Math.max(max - min, 1);
  const timeline = document.createElement('div');
  timeline.className = 'timeline';

  validItems.slice(-7).forEach(v=>{
    const item = document.createElement('div');
    item.className = 'timeline-item';
    appendText(item, 'div', v.title || '제목 없음', 'timeline-title');

    const track = document.createElement('div');
    track.className = 'timeline-track';
    track.title = `${getMonthKey(v.dateStart) || '-'} ~ ${getMonthKey(v.dateEnd) || getMonthKey(v.dateStart) || '-'}`;

    const fill = document.createElement('div');
    fill.className = 'timeline-fill';
    fill.style.left = `${Math.round(((v.start - min) / range) * 100)}%`;
    fill.style.width = `${Math.max(8, Math.round(((v.end - v.start) / range) * 100))}%`;
    track.appendChild(fill);

    item.appendChild(track);
    timeline.appendChild(item);
  });

  parent.appendChild(timeline);
}

