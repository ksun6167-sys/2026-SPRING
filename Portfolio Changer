<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>자기소개서 포트폴리오 관리</title>
<style>
:root{
  color-scheme:light;
  --bg:#f4f5f7;
  --panel:#ffffff;
  --text:#15171a;
  --muted:#626975;
  --line:#d7dbe2;
  --blue:#2563eb;
  --green:#0f9f6e;
  --red:#dc2626;
  --amber:#d97706;
  --ink:#111827;
}
*{box-sizing:border-box}
body{margin:0;font-family:Arial,"Noto Sans KR",sans-serif;background:var(--bg);color:var(--text)}
.container{max-width:1040px;margin:0 auto;padding:28px 18px 40px}
h1{text-align:center;margin:0 0 22px;font-size:28px}
.tabs{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-bottom:18px}
.tab-button{background:#e5e7eb;color:#343942;border:1px solid #d1d5db}
.tab-button.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.tab-panel{display:none}
.tab-panel.active{display:block}
.section-title{display:flex;align-items:center;justify-content:space-between;gap:12px;margin:0 0 12px}
.section-title h2{margin:0;font-size:20px}
.input-box{background:var(--panel);padding:16px;border:1px solid var(--line);border-radius:8px;margin-bottom:18px}
.form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
.full{grid-column:1/-1}
input,textarea,select{width:100%;padding:10px;border-radius:6px;border:1px solid #c7ccd5;background:#fff;color:var(--text);font:inherit}
textarea{min-height:96px;resize:vertical}
button{min-height:40px;padding:0 13px;border:none;border-radius:6px;background:var(--blue);color:#fff;cursor:pointer;font-weight:700}
button:hover{filter:brightness(.95)}
button:focus-visible,input:focus-visible,textarea:focus-visible,select:focus-visible{outline:3px solid rgba(37,99,235,.25);outline-offset:1px}
.toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:16px}
.toolbar input{flex:1 1 240px}
.toolbar select{max-width:180px}
.list{display:flex;flex-direction:column;gap:10px}
.card{background:var(--panel);padding:16px;border:1px solid var(--line);border-radius:8px;position:relative}
.card h3{margin:0 0 6px;padding-right:148px;font-size:20px;line-height:1.3}
.meta{font-size:13px;color:var(--muted);margin:6px 0}
.tags{display:flex;gap:5px;flex-wrap:wrap;margin:8px 0}
.tag{font-size:12px;background:#e8ebf0;padding:3px 7px;border-radius:4px;color:#343942}
.actions{position:absolute;top:12px;right:12px;display:flex;gap:5px}
.actions button{min-height:30px;padding:0 9px;font-size:12px}
.star{background:var(--amber)}
.delete{background:var(--red)}
.edit{background:var(--green)}
.detail{margin-top:8px;font-size:14px;line-height:1.6;white-space:pre-wrap}
.link{display:inline-block;margin-top:8px;color:#1d4ed8;font-weight:700;text-decoration:none}
.link:hover{text-decoration:underline}
.export-box{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:20px}
.export-box button,.dark{background:var(--ink)}
.empty{padding:28px;text-align:center;border:1px dashed #b9c0cc;border-radius:8px;color:var(--muted);background:#fff}
.notice{margin:0 0 12px;color:var(--muted);font-size:13px}
.analysis-box{background:var(--panel);padding:16px;border:1px solid var(--line);border-radius:8px;margin:0 0 18px}
.analysis-head{display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap;margin-bottom:12px}
.analysis-head h2{margin:0;font-size:20px}
.analysis-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.analysis-panel{border:1px solid var(--line);border-radius:8px;padding:14px;background:#fafafa}
.analysis-panel h3{margin:0 0 10px;font-size:16px}
.recommend-list{display:flex;flex-direction:column;gap:8px}
.recommend-item{display:flex;justify-content:space-between;gap:10px;align-items:center;border-bottom:1px solid #e4e7ec;padding-bottom:8px}
.recommend-item:last-child{border-bottom:none;padding-bottom:0}
.score{font-size:12px;color:#fff;background:var(--blue);border-radius:999px;padding:3px 8px;white-space:nowrap}
.keyword-list{display:flex;gap:6px;flex-wrap:wrap}
.keyword{background:#dbeafe;color:#1e3a8a;border-radius:999px;padding:5px 9px;font-size:13px;font-weight:700}
.sentence{margin:10px 0 0;color:#343942;line-height:1.6;font-size:14px}
.visual-box{background:var(--panel);padding:16px;border:1px solid var(--line);border-radius:8px;margin:0 0 18px}
.visual-head{display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap;margin-bottom:12px}
.visual-head h2{margin:0;font-size:20px}
.visual-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.visual-panel{border:1px solid var(--line);border-radius:8px;padding:14px;background:#fafafa;min-height:170px}
.visual-panel h3{margin:0 0 12px;font-size:16px}
.stat-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-bottom:12px}
.stat-card{background:#eef2ff;border:1px solid #d9e0ff;border-radius:8px;padding:12px}
.stat-value{display:block;font-size:24px;font-weight:800;color:#1d4ed8;line-height:1}
.stat-label{display:block;margin-top:6px;font-size:12px;color:#4b5563}
.bar-list{display:flex;flex-direction:column;gap:9px}
.bar-label{display:flex;justify-content:space-between;gap:10px;margin-bottom:4px;font-size:13px;color:#343942}
.bar-track{height:12px;border-radius:999px;background:#e5e7eb;overflow:hidden}
.bar-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,#2563eb,#14b8a6)}
.skill-cloud{display:flex;align-items:flex-end;gap:8px;flex-wrap:wrap;min-height:100px}
.skill-bubble{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;background:#ecfeff;color:#155e75;border:1px solid #a5f3fc;font-weight:800;line-height:1;padding:8px 10px}
.timeline{display:flex;flex-direction:column;gap:10px}
.timeline-item{display:grid;grid-template-columns:minmax(86px,130px) 1fr;gap:10px;align-items:center}
.timeline-title{font-size:13px;color:#343942;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.timeline-track{height:18px;background:#e5e7eb;border-radius:999px;overflow:hidden;position:relative}
.timeline-fill{position:absolute;top:0;bottom:0;min-width:8px;border-radius:999px;background:#10b981}
.profile-summary{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:12px}
.profile-item{background:#f8fafc;border:1px solid var(--line);border-radius:8px;padding:10px}
.profile-item strong{display:block;margin-bottom:4px;font-size:12px;color:#4b5563}
.experience-list{display:flex;flex-direction:column;gap:10px}
.outline-box{background:var(--panel);padding:16px;border:1px solid var(--line);border-radius:8px;margin:18px 0 0}
.outline-list{display:flex;flex-direction:column;gap:10px}
.outline-item{border:1px solid var(--line);border-radius:8px;background:#fafafa;padding:14px}
.outline-item h3{margin:0 0 8px;font-size:16px}
.outline-item p{margin:0;color:#343942;line-height:1.6}
@media (max-width:640px){
  .tabs{grid-template-columns:1fr}
  .form-grid{grid-template-columns:1fr}
  .analysis-grid{grid-template-columns:1fr}
  .visual-grid{grid-template-columns:1fr}
  .stat-row{grid-template-columns:1fr}
  .timeline-item{grid-template-columns:1fr}
  .profile-summary{grid-template-columns:1fr}
  .toolbar select{max-width:none}
  .card h3{padding-right:0;margin-top:38px}
  .actions{left:12px;right:auto}
}
</style>
</head>
<body>
<main class="container">
  <h1>자기소개서 포트폴리오 관리</h1>

  <nav class="tabs" aria-label="기록 탭">
    <button type="button" class="tab-button active" data-tab="profile" onclick="switchTab('profile')">인적사항</button>
    <button type="button" class="tab-button" data-tab="portfolio" onclick="switchTab('portfolio')">포트폴리오</button>
    <button type="button" class="tab-button" data-tab="experience" onclick="switchTab('experience')">자유경험</button>
  </nav>

  <section id="tab-profile" class="tab-panel active" aria-label="인적사항">
    <section class="input-box">
      <div class="section-title">
        <h2>인적사항</h2>
        <button type="button" onclick="saveProfile()">저장</button>
      </div>
      <div class="form-grid">
        <input id="profileName" placeholder="이름" autocomplete="off">
        <input id="profileBirth" type="date" aria-label="생년월일">
        <input id="profileEducation" placeholder="학력" autocomplete="off">
        <input id="profileMajor" placeholder="전공 / 관심 분야" autocomplete="off">
        <input id="profileEmail" placeholder="이메일" autocomplete="off">
        <input id="profilePhone" placeholder="연락처" autocomplete="off">
        <input id="profileTarget" class="full" placeholder="희망 직무 / 지원 분야" autocomplete="off">
        <textarea id="profileNote" class="full" placeholder="성향, 가치관, 자기소개에 꼭 넣고 싶은 정보"></textarea>
      </div>
      <div id="profileSummary" class="profile-summary"></div>
    </section>
  </section>

  <section id="tab-portfolio" class="tab-panel" aria-label="포트폴리오">
  <section class="input-box" aria-label="포트폴리오 기록 입력">
    <p class="notice" id="formStatus">새 기록을 추가하는 중입니다.</p>
    <div class="form-grid">
      <input id="title" placeholder="제목" autocomplete="off">
      <select id="category">
        <option value="영상">영상</option>
        <option value="대외활동">대외활동</option>
        <option value="알바">알바</option>
        <option value="학업">학업</option>
      </select>
      <input id="role" placeholder="역할" autocomplete="off">
      <input id="skills" placeholder="스킬 (쉼표로 구분)" autocomplete="off">
      <input id="dateStart" type="date" aria-label="시작 날짜">
      <input id="dateEnd" type="date" aria-label="종료 날짜">
      <textarea id="desc" class="full" placeholder="설명"></textarea>
      <input id="result" class="full" placeholder="성과" autocomplete="off">
      <input id="link" class="full" placeholder="링크 (선택)" autocomplete="off">
    </div>
    <div class="toolbar" style="margin:12px 0 0">
      <button type="button" id="saveButton" onclick="add()">추가</button>
      <button type="button" class="dark" onclick="resetForm()">취소</button>
    </div>
  </section>

  <section class="toolbar" aria-label="검색 및 필터">
    <input id="search" placeholder="검색" oninput="render()">
    <select id="filter" onchange="render()">
      <option value="all">전체</option>
      <option value="영상">영상</option>
      <option value="대외활동">대외활동</option>
      <option value="알바">알바</option>
      <option value="학업">학업</option>
      <option value="important">중요만</option>
    </select>
    <button type="button" onclick="showPortfolio()">포트폴리오 보기</button>
    <button type="button" class="dark" onclick="analyzePortfolio()">AI 분석</button>
  </section>

  <section class="analysis-box" aria-label="AI 포트폴리오 분석">
    <div class="analysis-head">
      <h2>AI 포트폴리오 분석</h2>
      <button type="button" onclick="analyzePortfolio()">다시 분석</button>
    </div>
    <div id="analysisResult" class="empty">기록을 추가한 뒤 AI 분석을 눌러 직무와 자기소개 키워드를 추천받아 보세요.</div>
  </section>

  <section class="visual-box" aria-label="포트폴리오 시각화">
    <div class="visual-head">
      <h2>포트폴리오 시각화</h2>
      <button type="button" onclick="renderVisuals()">새로고침</button>
    </div>
    <div id="visualResult" class="empty">기록을 추가하면 카테고리, 스킬, 활동 기간이 차트로 표시됩니다.</div>
  </section>

  <section class="list" id="list" aria-live="polite"></section>

  <section class="export-box" aria-label="데이터 백업">
    <button type="button" onclick="exportData()">데이터 다운로드(JSON)</button>
    <input id="importFile" type="file" accept="application/json,.json" onchange="importData(event)">
  </section>
  </section>

  <section id="tab-experience" class="tab-panel" aria-label="자유경험">
    <section class="input-box">
      <p class="notice" id="experienceStatus">새 자유경험을 추가하는 중입니다.</p>
      <div class="form-grid">
        <input id="experienceTitle" placeholder="경험 제목" autocomplete="off">
        <select id="experienceType">
          <option value="성장">성장</option>
          <option value="갈등 해결">갈등 해결</option>
          <option value="협업">협업</option>
          <option value="도전">도전</option>
          <option value="실패와 개선">실패와 개선</option>
          <option value="가치관">가치관</option>
        </select>
        <input id="experienceDate" type="date" aria-label="경험 날짜">
        <input id="experienceKeywords" placeholder="키워드 (쉼표로 구분)" autocomplete="off">
        <textarea id="experienceSituation" class="full" placeholder="상황 / 배경"></textarea>
        <textarea id="experienceAction" class="full" placeholder="내가 한 행동"></textarea>
        <textarea id="experienceResult" class="full" placeholder="결과 / 배운 점"></textarea>
      </div>
      <div class="toolbar" style="margin:12px 0 0">
        <button type="button" id="experienceSaveButton" onclick="addExperience()">추가</button>
        <button type="button" class="dark" onclick="resetExperienceForm()">취소</button>
      </div>
    </section>
    <section class="experience-list" id="experienceList" aria-live="polite"></section>
  </section>

  <section class="outline-box" aria-label="자기소개서 개요 생성">
    <div class="analysis-head">
      <h2>자기소개서 개요 AI 생성</h2>
      <button type="button" onclick="generateCoverLetterOutline()">개요 생성</button>
    </div>
    <div id="outlineResult" class="empty">인적사항, 포트폴리오, 자유경험을 바탕으로 자기소개서 개요를 만들어 줍니다.</div>
  </section>
</main>

<script>
const STORAGE_KEY = 'portfolio';
const PROFILE_KEY = 'portfolioProfile';
const EXPERIENCE_KEY = 'portfolioExperiences';
let editId = null;
let experienceEditId = null;

const fields = {
  title: document.getElementById('title'),
  category: document.getElementById('category'),
  role: document.getElementById('role'),
  skills: document.getElementById('skills'),
  dateStart: document.getElementById('dateStart'),
  dateEnd: document.getElementById('dateEnd'),
  desc: document.getElementById('desc'),
  result: document.getElementById('result'),
  link: document.getElementById('link')
};

const profileFields = {
  name: document.getElementById('profileName'),
  birth: document.getElementById('profileBirth'),
  education: document.getElementById('profileEducation'),
  major: document.getElementById('profileMajor'),
  email: document.getElementById('profileEmail'),
  phone: document.getElementById('profilePhone'),
  target: document.getElementById('profileTarget'),
  note: document.getElementById('profileNote')
};

const experienceFields = {
  title: document.getElementById('experienceTitle'),
  type: document.getElementById('experienceType'),
  date: document.getElementById('experienceDate'),
  keywords: document.getElementById('experienceKeywords'),
  situation: document.getElementById('experienceSituation'),
  action: document.getElementById('experienceAction'),
  result: document.getElementById('experienceResult')
};

function readJson(key, fallback){
  try{
    const parsed = JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
    return parsed ?? fallback;
  }catch{
    return fallback;
  }
}

function writeJson(key, value){
  localStorage.setItem(key, JSON.stringify(value));
}

function switchTab(tabName){
  document.querySelectorAll('.tab-button').forEach(button=>{
    button.classList.toggle('active', button.dataset.tab === tabName);
  });
  document.querySelectorAll('.tab-panel').forEach(panel=>{
    panel.classList.toggle('active', panel.id === `tab-${tabName}`);
  });
}

function getProfile(){
  const data = readJson(PROFILE_KEY, {});
  return data && typeof data === 'object' && !Array.isArray(data) ? data : {};
}

function saveProfileData(data){
  writeJson(PROFILE_KEY, data);
}

function getExperiences(){
  const data = readJson(EXPERIENCE_KEY, []);
  return Array.isArray(data) ? data : [];
}

function saveExperiences(data){
  writeJson(EXPERIENCE_KEY, data);
}

function getData(){
  try{
    const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    return Array.isArray(parsed) ? parsed : [];
  }catch{
    return [];
  }
}

function saveData(data){
  writeJson(STORAGE_KEY, data);
}

function saveProfile(){
  const profile = {};
  Object.entries(profileFields).forEach(([key, field])=>{
    profile[key] = field.value.trim();
  });
  saveProfileData(profile);
  renderProfile();
  generateCoverLetterOutline(false);
}

function renderProfile(){
  const profile = getProfile();
  Object.entries(profileFields).forEach(([key, field])=>{
    field.value = profile[key] || '';
  });

  const summary = document.getElementById('profileSummary');
  summary.replaceChildren();
  const items = [
    ['이름', profile.name],
    ['생년월일', profile.birth],
    ['학력', profile.education],
    ['전공 / 관심 분야', profile.major],
    ['희망 직무', profile.target],
    ['메모', profile.note]
  ].filter(([,value])=>value);

  if(!items.length){
    appendText(summary, 'div', '저장된 인적사항이 없습니다.', 'empty');
    return;
  }

  items.forEach(([label, value])=>{
    const item = document.createElement('div');
    item.className = 'profile-item';
    appendText(item, 'strong', label);
    appendText(item, 'span', value);
    summary.appendChild(item);
  });
}

function normalizeUrl(url){
  const trimmed = url.trim();
  if(!trimmed) return '';
  if(/^https?:\/\//i.test(trimmed)) return trimmed;
  return `https://${trimmed}`;
}

function getFormItem(previous){
  return {
    id: editId || Date.now(),
    title: fields.title.value.trim(),
    category: fields.category.value,
    role: fields.role.value.trim(),
    skills: fields.skills.value.split(',').map(s=>s.trim()).filter(Boolean),
    dateStart: fields.dateStart.value.trim(),
    dateEnd: fields.dateEnd.value.trim(),
    desc: fields.desc.value.trim(),
    result: fields.result.value.trim(),
    link: normalizeUrl(fields.link.value),
    important: previous ? Boolean(previous.important) : false
  };
}

function add(){
  const data = getData();
  const previous = editId ? data.find(v=>v.id === editId) : null;
  const item = getFormItem(previous);

  if(!item.title){
    alert('제목을 입력해 주세요.');
    fields.title.focus();
    return;
  }

  const nextData = editId
    ? data.map(v=>v.id === editId ? item : v)
    : [...data, item];

  saveData(nextData);
  resetForm();
  render();
}

function resetForm(){
  Object.values(fields).forEach(field=>{
    if(field.tagName === 'SELECT') field.selectedIndex = 0;
    else field.value = '';
  });
  editId = null;
  document.getElementById('saveButton').textContent = '추가';
  document.getElementById('formStatus').textContent = '새 기록을 추가하는 중입니다.';
}

function editItem(id){
  const v = getData().find(x=>x.id === id);
  if(!v) return;
  fields.title.value = v.title || '';
  fields.category.value = v.category || '영상';
  fields.role.value = v.role || '';
  fields.skills.value = Array.isArray(v.skills) ? v.skills.join(', ') : '';
  fields.dateStart.value = v.dateStart || '';
  fields.dateEnd.value = v.dateEnd || '';
  fields.desc.value = v.desc || '';
  fields.result.value = v.result || '';
  fields.link.value = v.link || '';
  editId = id;
  document.getElementById('saveButton').textContent = '수정 저장';
  document.getElementById('formStatus').textContent = `"${v.title}" 기록을 수정하는 중입니다.`;
  window.scrollTo({top:0,behavior:'smooth'});
}

function toggleStar(id){
  const data = getData().map(v=>v.id === id ? {...v, important: !v.important} : v);
  saveData(data);
  render();
}

function remove(id){
  const item = getData().find(v=>v.id === id);
  if(!item || !confirm(`"${item.title}" 기록을 삭제할까요?`)) return;
  saveData(getData().filter(v=>v.id !== id));
  if(editId === id) resetForm();
  render();
}

function getExperienceFormItem(previous){
  return {
    id: experienceEditId || Date.now(),
    title: experienceFields.title.value.trim(),
    type: experienceFields.type.value,
    date: experienceFields.date.value.trim(),
    keywords: experienceFields.keywords.value.split(',').map(v=>v.trim()).filter(Boolean),
    situation: experienceFields.situation.value.trim(),
    action: experienceFields.action.value.trim(),
    result: experienceFields.result.value.trim(),
    important: previous ? Boolean(previous.important) : false
  };
}

function addExperience(){
  const data = getExperiences();
  const previous = experienceEditId ? data.find(v=>v.id === experienceEditId) : null;
  const item = getExperienceFormItem(previous);

  if(!item.title){
    alert('경험 제목을 입력해 주세요.');
    experienceFields.title.focus();
    return;
  }

  const nextData = experienceEditId
    ? data.map(v=>v.id === experienceEditId ? item : v)
    : [...data, item];

  saveExperiences(nextData);
  resetExperienceForm();
  renderExperiences();
  generateCoverLetterOutline(false);
}

function resetExperienceForm(){
  Object.values(experienceFields).forEach(field=>{
    if(field.tagName === 'SELECT') field.selectedIndex = 0;
    else field.value = '';
  });
  experienceEditId = null;
  document.getElementById('experienceSaveButton').textContent = '추가';
  document.getElementById('experienceStatus').textContent = '새 자유경험을 추가하는 중입니다.';
}

function editExperience(id){
  const item = getExperiences().find(v=>v.id === id);
  if(!item) return;
  experienceFields.title.value = item.title || '';
  experienceFields.type.value = item.type || '성장';
  experienceFields.date.value = item.date || '';
  experienceFields.keywords.value = Array.isArray(item.keywords) ? item.keywords.join(', ') : '';
  experienceFields.situation.value = item.situation || '';
  experienceFields.action.value = item.action || '';
  experienceFields.result.value = item.result || '';
  experienceEditId = id;
  document.getElementById('experienceSaveButton').textContent = '수정 저장';
  document.getElementById('experienceStatus').textContent = `"${item.title}" 경험을 수정하는 중입니다.`;
  switchTab('experience');
}

function removeExperience(id){
  const item = getExperiences().find(v=>v.id === id);
  if(!item || !confirm(`"${item.title}" 경험을 삭제할까요?`)) return;
  saveExperiences(getExperiences().filter(v=>v.id !== id));
  if(experienceEditId === id) resetExperienceForm();
  renderExperiences();
  generateCoverLetterOutline(false);
}

function toggleExperienceStar(id){
  const data = getExperiences().map(v=>v.id === id ? {...v, important: !v.important} : v);
  saveExperiences(data);
  renderExperiences();
  generateCoverLetterOutline(false);
}

function appendText(parent, tag, text, className){
  const el = document.createElement(tag);
  if(className) el.className = className;
  el.textContent = text;
  parent.appendChild(el);
