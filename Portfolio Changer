<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>나만의 포트폴리오</title>
    <style>
        /* 전체적인 디자인 */
        body {
            font-family: 'Pretendard', sans-serif;
            background-color: #f4f7f6;
            color: #333;
            margin: 0;
            padding: 40px 20px;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 30px;
        }
        
        /* 입력 영역 스타일 */
        .input-section {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            margin-bottom: 40px;
        }
        input, textarea {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-sizing: border-box;
            font-size: 15px;
        }
        textarea {
            resize: vertical;
            min-height: 100px;
        }
        button {
            width: 100%;
            padding: 14px;
            background-color: #2980b9;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #3498db;
        }

        /* 포트폴리오 리스트 영역 스타일 */
        .portfolio-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        .portfolio-item {
            background: #fff;
            padding: 20px;
            border-radius: 12px;
            border-left: 5px solid #2980b9;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            position: relative;
        }
        .portfolio-item h3 {
            margin: 0 0 10px 0;
            color: #2c3e50;
        }
        .portfolio-item .date {
            font-size: 13px;
            color: #7f8c8d;
            margin-bottom: 10px;
        }
        .portfolio-item .desc {
            line-height: 1.6;
            white-space: pre-wrap; 
        }
        
        /* 미디어(영상/이미지) 영역 스타일 */
        .media-container {
            margin-top: 15px;
            border-radius: 8px;
            overflow: hidden;
            background-color: #000; /* 영상/이미지 배경을 까맣게 */
        }
        .media-container iframe {
            width: 100%;
            aspect-ratio: 16 / 9; /* 유튜브 영상 비율 맞춤 */
            display: block;
        }
        .media-container img {
            width: 100%;
            max-height: 400px;
            object-fit: contain; /* 이미지 비율 안 깨지게 */
            display: block;
        }

        .delete-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: #e74c3c;
            width: auto;
            padding: 6px 12px;
            font-size: 12px;
        }
        .delete-btn:hover {
            background: #c0392b;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>My Portfolio</h1>

        <div class="input-section">
            <input type="text" id="title" placeholder="프로젝트/경력명 (예: 유튜브 채널 '제공피' 기획 및 운영)">
            <input type="text" id="date" placeholder="참여 기간 (예: 2024.03 ~ 2025.02)">
            <textarea id="description" placeholder="상세 역할 및 성과 (예: 구독자 1.5만명 달성, 단편영화 메인 PD 및 음향 감독 참여 등)"></textarea>
            <input type="text" id="mediaLink" placeholder="유튜브 영상 링크 또는 이미지 URL (선택사항)">
            <button onclick="addPortfolio()">경력 추가하기</button>
        </div>

        <div class="portfolio-list" id="portfolioList"></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', loadPortfolios);

        function addPortfolio() {
            const title = document.getElementById('title').value;
            const date = document.getElementById('date').value;
            const description = document.getElementById('description').value;
            const mediaLink = document.getElementById('mediaLink').value;

            if(!title || !description) {
                alert('프로젝트명과 상세 역할은 필수 입력사항입니다!');
                return;
            }

            const portfolioItem = {
                id: Date.now(),
                title: title,
                date: date,
                description: description,
                mediaLink: mediaLink // 미디어 링크 저장
            };

            let portfolios = JSON.parse(localStorage.getItem('myPortfolios')) || [];
            portfolios.push(portfolioItem);
            localStorage.setItem('myPortfolios', JSON.stringify(portfolios));
            
            // 입력창 초기화
            document.getElementById('title').value = '';
            document.getElementById('date').value = '';
            document.getElementById('description').value = '';
            document.getElementById('mediaLink').value = '';

            renderPortfolios();
        }

        function deletePortfolio(id) {
            let portfolios = JSON.parse(localStorage.getItem('myPortfolios')) || [];
            portfolios = portfolios.filter(item => item.id !== id);
            localStorage.setItem('myPortfolios', JSON.stringify(portfolios));
            renderPortfolios();
        }

        function renderPortfolios() {
            const listElement = document.getElementById('portfolioList');
            listElement.innerHTML = ''; 

            const portfolios = JSON.parse(localStorage.getItem('myPortfolios')) || [];

            portfolios.slice().reverse().forEach(item => {
                const itemDiv = document.createElement('div');
                itemDiv.className = 'portfolio-item';
                
                // 유튜브 링크인지 판별하는 정규식
                let mediaHTML = '';
                if (item.mediaLink) {
                    const ytMatch = item.mediaLink.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/i);
                    
                    if (ytMatch && ytMatch[1]) {
                        // 유튜브 영상일 경우 iframe으로 임베드
                        mediaHTML = `
                            <div class="media-container">
                                <iframe src="https://www.youtube.com/embed/${ytMatch[1]}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                            </div>
                        `;
                    } else {
                        // 일반 이미지 URL일 경우 img 태그 사용
                        mediaHTML = `
                            <div class="media-container">
                                <img src="${item.mediaLink}" alt="포트폴리오 첨부 이미지" onerror="this.style.display='none';">
                            </div>
                        `;
                    }
                }

                itemDiv.innerHTML = `
                    <h3>${item.title}</h3>
                    <div class="date">${item.date}</div>
                    <div class="desc">${item.description}</div>
                    ${mediaHTML}
                    <button class="delete-btn" onclick="deletePortfolio(${item.id})">삭제</button>
                `;
                listElement.appendChild(itemDiv);
            });
        }

        function loadPortfolios() {
            renderPortfolios();
        }
    </script>

</body>
</html>
