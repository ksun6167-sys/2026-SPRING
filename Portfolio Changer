function analyzeStrengths(data){
  const text = getPortfolioText(data);
  const strengthRules = [
    {keyword:'기획력', words:['기획','구성','아이디어','주제','콘셉트','전략','기획서']},
    {keyword:'실행력', words:['제작','진행','운영','완성','실행','업로드','참여','담당']},
    {keyword:'문제 해결력', words:['문제','해결','개선','보완','수정','피드백','오류','효율']},
    {keyword:'협업력', words:['협업','팀','조율','소통','회의','역할','리더','커뮤니케이션']},
    {keyword:'분석력', words:['분석','성과','결과','데이터','조회수','전환','비교','평가']},
    {keyword:'표현력', words:['영상','디자인','편집','스토리','발표','카피','콘텐츠','시각화']},
    {keyword:'책임감', words:['알바','운영','관리','마감','일정','고객','응대','담당']},
    {keyword:'성장지향', words:['학습','공부','도전','스터디','자격증','연습','개발','성장']}
  ];

  const scored = strengthRules
    .map(item=>({...item, score: countMatches(text, item.words)}))
    .filter(item=>item.score > 0)
    .sort((a,b)=>b.score - a.score)
    .slice(0, 6);

  const skillCounts = new Map();
  data.forEach(v=>{
    (Array.isArray(v.skills) ? v.skills : []).forEach(skill=>{
      const key = skill.trim();
      if(key) skillCounts.set(key, (skillCounts.get(key) || 0) + 1);
    });
  });

  const frequentSkills = [...skillCounts.entries()]
    .sort((a,b)=>b[1] - a[1])
    .slice(0, 5)
    .map(([skill])=>skill);

  return {
    strengths: scored.map(item=>item.keyword),
    skills: frequentSkills
  };
}

